modules = ["nodejs-20", "postgresql-16"]

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 22965
externalPort = 3001

[[ports]]
localPort = 24227
externalPort = 80

[[ports]]
localPort = 24382
externalPort = 3000

[agent]
expertMode = true

[userenv]

[userenv.shared]
PORT = "8080"
NODE_ENV = "development"
BASE_PATH = "/"
APP_URL = "https://98e59e1f-c999-4a68-9b83-910ab2aa90f1-00-3u9flehs6ip7v.pike.replit.dev"
WEB_APP_URL = "https://98e59e1f-c999-4a68-9b83-910ab2aa90f1-00-3u9flehs6ip7v.pike.replit.dev"
EXPO_PUBLIC_DOMAIN = "98e59e1f-c999-4a68-9b83-910ab2aa90f1-00-3u9flehs6ip7v.pike.replit.dev"
JWT_SECRET = "dev-secret-key-change-in-production"

[nix]
channel = "stable-25_05"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/web-app && pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
