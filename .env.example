# DO Deployment Environment Variables

# ==========================================
# 1. Database (Provided by DigitalOcean)
# ==========================================
# Example: postgres://user:password@hostname:port/dbname?sslmode=require
DATABASE_URL=""

# ==========================================
# 2. Required Custom Secrets (You must create)
# ==========================================
# A random, secure string for signing JWT tokens (use `openssl rand -hex 32` to generate)
JWT_SECRET=""

# The public URL where your API server will be hosted (e.g., https://api.yourdomain.com)
APP_URL=""

# The public URL where your Web App will be hosted (e.g., https://app.yourdomain.com)
WEB_APP_URL=""

# Used by the mobile app to know the API domain (e.g., api.yourdomain.com)
# Should match the host of APP_URL without protocol
EXPO_PUBLIC_DOMAIN=""

# ==========================================
# 3. Standard / Execution Variables
# ==========================================
# Usually provided by DO App Platform automatically
PORT="8080"
NODE_ENV="production"
BASE_PATH="/"

# ==========================================
# 4. Optional Configurations (Payments, AI)
# ==========================================
AI_INTEGRATIONS_OPENAI_BASE_URL="https://api.openai.com/v1"
AI_INTEGRATIONS_OPENAI_API_KEY=""

CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
PAYME_MERCHANT_ID=""
PAYNET_MERCHANT_ID=""
PAYNET_SERVICE_ID=""
